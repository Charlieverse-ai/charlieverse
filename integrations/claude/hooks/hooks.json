{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "charlie hooks session-start --source 'claude-plugin'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "charlie hooks prompt-submit --source 'claude-plugin'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "charlie hooks stop --source 'claude-plugin'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "charlie hooks tool-use --source 'claude-plugin'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "charlie hooks save-reminder --source 'claude-plugin'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
